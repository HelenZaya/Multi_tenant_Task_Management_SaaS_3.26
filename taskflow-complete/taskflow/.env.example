# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://taskflow:taskflow_secret@localhost:5432/taskflow
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-64-char-random-string-in-production-now
JWT_REFRESH_SECRET=change-me-to-another-64-char-random-string-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Services (ports) ────────────────────────────────────
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
TENANT_SERVICE_PORT=3002
PROJECT_SERVICE_PORT=3003
TASK_SERVICE_PORT=3004
REALTIME_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006
ANALYTICS_SERVICE_PORT=3007
BILLING_SERVICE_PORT=3008
WORKER_SERVICE_PORT=3009

# ─── General ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
